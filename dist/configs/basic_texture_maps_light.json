{
    "header": "ValveTexture",
    "vtfcmd": "D:/Portable Program Files/maretf/maretf.exe",
    "vtf": {
        "LightWarp": {
            "input": ".*(^|[_-])warp([_-].*)?\\.(psd|png|tga|jpg|dds)$",
            "vtf": {
                "encoder_args": ["-format", "BGR888", "-alphaformat", "BGRA8888", "-rclampwidth", "256", "-rclampheight", "16", "-clamps", "-clampt"]
            }
        },
        "eye": {
            "input": ".*(^|[_-])eye([_-].*)?\\.(psd|png|tga|jpg|dds)$",
            "vtf": {
                "flags" : [],
                "encoder_args": ["-format", "DEFAULT", "-max-width", "512", "-max-height", "512", "-clamps", "-clampt"]
            }
        },
        "diffuse": {
            "input": ".*[_-](d|color|rgb)\\.(psd|png|tga|jpg|dds)$",
            "vtf":{
                "encoder_args": ["-format", "DEFAULT", "-max-width", "4096", "-max-height", "4096"]
            }
        },
        "normal": {
            "input": ".*[_-](n|normal)\\.(psd|png|tga|jpg|dds)$",
            "vtf": {
                "flags": ["NORMAL"],
                "encoder_args": ["-format", "DEFAULT", "-max-width", "4096", "-max-height", "4096"]
            }
        },
        "exponent": {
            "input": ".*(^|[_-])(e|exponent|phong)([_-].*)?\\.(psd|png|tga|jpg|dds)$",
            "vtf":{
                "encoder_args": ["-format", "DEFAULT", "-max-width", "4096", "-max-height", "4096"]
            }
        },
        "mrao": {
            "input": ".*(^|[_-])mrao([_-].*)?\\.(psd|png|tga|jpg|dds)$",
            "vtf":{
                "encoder_args": ["-format", "DEFAULT", "-max-width", "4096", "-max-height", "4096"]
            }
        },
        "emissive": {
            "input": ".*[_-]em(_flow|_base)?\\.(psd|png|tga|jpg|dds)$",
            "vtf": {
                "encoder_args": ["-format", "DEFAULT", "-max-width", "4096", "-max-height", "4096"]
            }
        }
    }
}